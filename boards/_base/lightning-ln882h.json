{
	"build": {
		"family": "LN882H",
		"f_cpu": "160000000L",
		"prefix": "arm-none-eabi-",
		"ldscript": "ln882hki_bsp.ld",
		"bootfile": "boot_ln882h.bin"
	},
	"flash": {
		"boot": "0x000000+0x6000",
		"part_table": "0x006000+0x1000",
		"app": "0x007000+0x12C000",
		"ota": "0x133000+0xAA000",
		"ln_nvds": "0x1DD000+0x3000",
		"ln_kv": "0x1E0000+0x4000",
		"kvs": "0x1E4000+0x8000",
		"userdata": "0x1EC000+0x14000"
	},
	"connectivity": [
		"wifi",
		"ble"
	],
	"debug": {
		"protocol": "openocd",
		"protocols": [
			"openocd"
		],
		"openocd_config": "ln882x.cfg",
		"gdb_init": [
			"mem 0x00000000 0x10000000 ro"
		]
	},
	"upload": {
		"maximum_size": 1228800,
		"maximum_ram_size": 302080,
		"flash_size": 2097152,
		"require_upload_port": true,
		"speed": 115200,
		"protocol": "uart",
		"protocols": [
			"uart"
		]
	},
	"doc": {
		"params": {
			"manufacturer": "Lightning",
			"series": "LN882X",
			"voltage": "3.0V - 3.6V",
			"extra": {
				"Wi-Fi": "802.11 b/g/n",
				"Bluetooth": "BLE v5.1"
			},
			"layout": "**SDK default** (OTA 0x133000, KV 0x1E0000)"
		},
		"flashing": {
			"links": {
				"ltchiptool user guide": "../../docs/flashing/tools/ltchiptool.md",
				"full flashing guide": "../../docs/platform/lightning-ln882x/README.md#flashing"
			},
			"pins": {
				"PA03 / RX0": "TX of USB-UART adapter",
				"PA02 / TX0": "RX of USB-UART adapter",
				"PA09 / BOOT1 (strapping pin)": "GND to enter download mode",
				"CEN (Chip-Enable)": "GND to reset the chip"
			},
			"guide": [
				"Connect the USB-UART adapter.",
				"Start the flashing process.",
				"Connect PA09 (BOOT1) to GND.",
				"Power-cycle the device or briefly short CEN to GND."
			]
		},
		"links": {
			"Info & flashing guide": "../../docs/platform/lightning-ln882x/README.md",
			"Debugging": "../../docs/platform/lightning-ln882x/debugging.md"
		}
	}
}
